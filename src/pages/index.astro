---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/theme/ThemeToggle.jsx';
---

<Layout>
  <header>
    <h1 class="typing-effect">Jacob George</h1>
    <nav style="display: flex; align-items: center; gap: 1.5rem;">
      <a href="#about">About</a>
      <a href="#skills">Skills</a>
      <a href="#projects">Projects</a>
      <a href="#resume">Resume</a>
      <a href="#contact">Contact</a>
      <ThemeToggle client:load />
    </nav>
  </header>

  <div class="container">
    <section id="about">
      <h2>About Me</h2>
      <p>
        I'm a Software Engineer with a background in systems architecture. Currently at Dell Technologies
        as a Systems Engineer, I build customized OEM solutions while pursuing my deeper passion:
        full-stack development and cloud-native AI platforms.
      </p>
      <p>
        I graduated from the University of Texas at Austin in 2023 with a degree in Electrical &amp; Computer
        Engineering, focused on software. Since then I've gone deep on the Microsoft cloud ecosystem &mdash;
        building with Azure, Power Platform, and Copilot Studio &mdash; alongside production backend work
        with Flask, Redis, Docker, and CI/CD pipelines.
      </p>
      <p>
        My programming journey started in high school when I accidentally enrolled in a senior-level
        Computer Science course. That happy accident turned into a career, and I've been building ever since.
      </p>
    </section>

    <section id="skills">
      <h2 class="typing-tech-stack" style="display:inline-block; border-bottom: none;">Tech Stack</h2>
      <div class="skills-grid" style="margin-top: 1.5rem;">
        {["Python", "TypeScript", "React", "Astro", "Flask", "Redis", "MongoDB", "Docker", "Azure", "Power Platform", "Copilot Studio", "GitHub Actions", "REST APIs", "CI/CD"].map((tech, index) => (
            <span class="tech-tag skill-badge" style={`animation-delay: ${1.5 + (index * 0.1)}s`}>{tech}</span>
        ))}
      </div>
    </section>

    <section id="projects">
      <h2>Projects</h2>
      <div class="projects-grid">
        <div class="project-card">
          <h3>Copilot Onboarding Agent</h3>
          <p>AI-powered HR onboarding agent built with Copilot Studio, Power Platform, and a Flask API on Azure. Guides new employees through structured workflows.</p>
          <div class="card-tags">
            <span class="card-tag">Azure</span>
            <span class="card-tag">Copilot Studio</span>
            <span class="card-tag">Power Platform</span>
          </div>
          <a href="/projects/copilot-onboarding-agent" class="project-link">View Project</a>
        </div>
        <div class="project-card">
          <h3>Distributed Job System</h3>
          <p>Async distributed job queue with Flask, Redis, and Docker. Retry logic, dead-letter queue, structured logging, and full test suite.</p>
          <div class="card-tags">
            <span class="card-tag">Flask</span>
            <span class="card-tag">Redis</span>
            <span class="card-tag">Docker</span>
          </div>
          <a href="/projects/distributed-job-system" class="project-link">View Project</a>
        </div>
        <div class="project-card">
          <h3>HaaS Platform</h3>
          <p>Full-stack hardware checkout system with React, Flask, MongoDB, and JWT authentication. Dockerized for deployment.</p>
          <div class="card-tags">
            <span class="card-tag">React</span>
            <span class="card-tag">Flask</span>
            <span class="card-tag">MongoDB</span>
          </div>
          <a href="/projects/haas-platform" class="project-link">View Project</a>
        </div>
        <div class="project-card">
          <h3>Hand Sign Detector</h3>
          <p>Real-time gesture recognition using Python, OpenCV, and MediaPipe for computer vision-based interaction.</p>
          <div class="card-tags">
            <span class="card-tag">Python</span>
            <span class="card-tag">OpenCV</span>
            <span class="card-tag">MediaPipe</span>
          </div>
          <a href="/projects/hand-sign-detector" class="project-link">View Project</a>
        </div>
      </div>
    </section>

    <section id="resume">
      <h2>Resume</h2>
      <p>My resume is available for download below.</p>
      <a href="/Jacob-George-Resume-200029159.pdf" class="button" target="_blank">View Resume</a>
    </section>

    <section id="contact">
      <h2>Contact</h2>
      <p>Interested in working together? Reach out!</p>
      <p>Email: <a href="mailto:jacob.c.george333@gmail.com">jacob.c.george333@gmail.com</a></p>
      <p>LinkedIn: <a href="https://www.linkedin.com/in/jacobcgeorge/" target="_blank">jacobcgeorge</a></p>
      <p>GitHub: <a href="https://github.com/jacobgeorge3" target="_blank">jacobgeorge3</a></p>
    </section>
  </div>

  <footer>
    <p>&copy; 2026 Jacob George. All rights reserved.</p>
  </footer>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Select all outbound or interaction links (skipping smooth-scroll nav links)
      const links = document.querySelectorAll('a:not([href^="#"])');

      links.forEach(link => {
        link.addEventListener('click', (e) => {
          const isClimbing = document.documentElement.getAttribute('data-theme') === 'climbing';

          if (isClimbing) {
            e.preventDefault();
            const href = link.getAttribute('href');
            const targetAttr = link.getAttribute('target');

            const rect = link.getBoundingClientRect();
            const gutterOffset = window.innerWidth * 0.10;
            
            // The new sprite width is 80px, centered on the gutter.
            // The climber container's X is `gutterOffset - 40px`.
            // The target `x` is `rect.left`. Subtracting the container's X gives the relative X.
            // Subtract an additional 20px so the left arm aligns with the left bound of the link.
            const targetX = rect.left - (gutterOffset - 40) - 20;
            
            // The Y target is the viewport-relative top of the element.
            const targetViewportY = rect.top;

            const event = new CustomEvent('climber-swing', {
              detail: { targetX, targetViewportY, href, targetAttr }
            });
            window.dispatchEvent(event);
          }
        });
      });
    });
  </script>
</Layout>
