---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/theme/ThemeToggle.jsx';
---

<Layout>
  <header>
    <h1 class="typing-effect">Jacob George</h1>
    <nav style="display: flex; align-items: center; gap: 1.5rem;">
      <a href="#about">About</a>
      <a href="#projects">Projects</a>
      <a href="#resume">Resume</a>
      <a href="#contact">Contact</a>
      <ThemeToggle client:load />
    </nav>
  </header>

  <div class="container">
    <section id="about">
      <h2>About Me</h2>
      <p>Hi! My name is Jacob George and I'm a Systems Engineer at Dell Technologies. I provide customized solutions to
        my OEM customers that they in turn provide to their end users.
        I graduated from the University of Texas in 2023 with a degree in Electrical & Computer Engineering. My focus
        was in Software Engineering and this is where my passion lies.
        My programming career began in highscool when I accidentally signed up for a Senior level Computer Science
        course. Since then my love for software develpment, hardware design, and system architecture has only grown.
      </p>
    </section>

    <section id="projects">
      <h2>Projects</h2>
      <div class="projects-grid">
        <div class="project-card">
          <h3>Hand Sign Detector</h3>
          <p>Real-time gesture recognition using Python, OpenCV, and MediaPipe.</p>
          <a href="/projects/hand-sign-detector" class="project-link">View Project</a>
        </div>
        <div class="project-card">
          <h3>Distributed Job System</h3>
          <p>Scalable async task queue using Python, Flask, Redis, and Docker.</p>
          <a href="/projects/distributed-job-system" class="project-link">View Project</a>
        </div>
        <div class="project-card">
          <h3>HaaS Platform</h3>
          <p>Full-stack hardware rental platform with React, Flask, and Docker.</p>
          <a href="/projects/haas-platform" class="project-link">View Project</a>
        </div>
        <div class="project-card">
          <h3>Copilot Studio Customer Onboarding Agent</h3>
          <p>AI agent built with Azure OpenAI and Copilot Studio to parse vendor documents.</p>
          <a href="/projects/copilot-onboarding-agent" class="project-link">View Project</a>
        </div>
      </div>
    </section>

    <section id="resume">
      <h2>Resume</h2>
      <p>My resume is available for download below.</p>
      <a href="/Jacob-George-Resume- 200007560.pdf" class="button" target="_blank">View Resume</a>
    </section>

    <section id="contact">
      <h2>Contact</h2>
      <p>Interested in working together? Reach out!</p>
      <p>Email: <a href="mailto:jacob.c.george333@gmail.com">jacob.c.george333@gmail.com</a></p>
      <p>LinkedIn: <a href="https://www.linkedin.com/in/jacobcgeorge/" target="_blank">jacobcgeorge</a></p>
      <p>GitHub: <a href="https://github.com/jacobgeorge3" target="_blank">jacobgeorge3</a></p>
    </section>
  </div>

  <footer>
    <p>&copy; 2025 Jacob George. All rights reserved.</p>
  </footer>
</Layout>
